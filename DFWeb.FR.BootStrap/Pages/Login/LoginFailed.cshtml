@page
@model Page
@{
    ViewData["Title"] = "Login Failed";
}

@section Navigation {
    @await Html.PartialAsync("../../Views/TopElements/TopMenuBasic.cshtml", Model)
}

<div class="row">
    <div class="col-lg-6 offset-lg-3">
        <div class="card shadow-lg fade-in">
            <div class="card-body p-5">
                <div class="alert alert-danger mb-4" role="alert">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fas fa-exclamation-circle fs-4"></i>
                        <div>
                            <strong>Login Failed</strong>
                            <p class="mb-0 small mt-1">Unknown username or password.</p>
                        </div>
                    </div>
                </div>

                <form action="/api/Login" method="POST" class="mb-4">
                    <div class="mb-3">
                        <label for="username" class="form-label fw-bold">Username</label>
                        <input name="username" id="username" class="form-control form-control-lg" 
                               type="text" placeholder="Enter your username" aria-label="Username">
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold">Password</label>
                        <input name="password" id="password" class="form-control form-control-lg" 
                               type="password" placeholder="Enter your password" aria-label="Password">
                    </div>

                    <button class="btn btn-primary btn-lg w-100" type="submit">
                        <i class="fas fa-sign-in-alt me-2"></i> Sign In
                    </button>
                </form>

                <div class="text-center">
                    <p class="mb-0 text-muted">Forgot your password?</p>
                    <a href="/Login/ChangePassStep1" class="btn btn-link btn-sm mt-2">
                        <i class="fas fa-key"></i> Reset Password
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

