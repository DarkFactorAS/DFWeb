@using DFWeb.BE.Models
@model TeaserPageContentModel

@{
    string FormatTags(string tags)
    {
        tags = tags.ToUpper();
        tags = tags.Replace(" ", " • ");
        tags = tags.Replace("_", " ");
        return tags;
    }
}

<div class="card article h-100 shadow-sm fade-in overflow-hidden">
    @if (Model.ImageId != 0)
    {
        <div class="overflow-hidden" style="height: 200px;">
            <a href="/page?id=@Model.PageId" class="d-block h-100">
                <img width="100%" height="100%" src="/api/Image/GetImage?imageId=@Model.ImageId" 
                     class="imagefit img-fluid" alt="@Model.ContentTitle"
                     style="transition: transform 0.3s ease; object-fit: cover; width: 100%; height: 100%;">
            </a>
        </div>
    }

    <div class="card-body d-flex flex-column">
        @if (!string.IsNullOrEmpty(Model.Tags))
        {
            <div class="mb-2">
                <small class="badge bg-secondary">@FormatTags(Model.Tags)</small>
            </div>
        }
        
        <h3 class="card-title article_title">
            <a href="/page?id=@Model.PageId" class="text-decoration-none">@Model.ContentTitle</a>
        </h3>
        
        <small class="text-muted mb-2">
            <i class="fas fa-calendar-alt"></i> @Model.LastUpdated
        </small>
        
        <p class="card-text article_promo flex-grow-1">@Model.PromoText</p>
        
        <a href="/page?id=@Model.PageId" class="btn btn-outline-primary btn-sm align-self-start mt-auto">
            Read More <i class="fas fa-arrow-right ms-2"></i>
        </a>
    </div>
</div>