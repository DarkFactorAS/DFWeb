@using DFWeb.BE.Models
@model TeaserPageContentModel

@{
    string FormatTags(string tags)
    {
        tags = tags.ToUpper();
        tags = tags.Replace(" ", " • ");
        tags = tags.Replace("_", " ");
        return tags;
    }
}

<article class="article_featured fade-in">
    @if (Model.ImageId != 0)
    {
        <div class="mb-3 overflow-hidden rounded">
            <a href="/page?id=@Model.PageId" class="d-block">
                <img width="100%" src="/api/Image/GetImage?imageId=@Model.ImageId" 
                     class="imagefit img-fluid" alt="@Model.ContentTitle"
                     style="transition: transform 0.3s ease; transform: scale(1);">
            </a>
        </div>
    }
    
    <div>
        <h1 class="article_title">
            <a href="/page?id=@Model.PageId">@Model.ContentTitle</a>
        </h1>
        
        <div class="d-flex gap-2 align-items-center flex-wrap mb-2">
            <small class="text-muted">
                <i class="fas fa-calendar-alt"></i> @Model.LastUpdated
            </small>
            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <div class="badge bg-info text-dark">@FormatTags(Model.Tags)</div>
            }
        </div>
        
        <p class="article_promo lead">@Model.PromoText</p>
        
        <a href="/page?id=@Model.PageId" class="btn btn-primary btn-sm">
            Read More <i class="fas fa-arrow-right ms-2"></i>
        </a>
    </div>
</article>
