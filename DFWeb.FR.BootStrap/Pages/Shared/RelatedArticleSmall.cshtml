@using DFWeb.BE.Models
@model List<TeaserPageContentModel>

@{
    string FormatTags(string tags)
    {
        if (string.IsNullOrEmpty(tags)) return "";
        tags = tags.ToUpper();
        tags = tags.Replace(" ", " • ");
        tags = tags.Replace("_", " ");
        return tags;
    }
}

<aside>
    <h3 class="mb-4 pb-3 border-bottom">
        <i class="fas fa-link"></i> Related Articles
    </h3>

    @if (!Model.Any())
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> No related articles available.
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var relPage in Model)
            {
                <div class="card article shadow-sm fade-in overflow-hidden mb-3">
                    @if (relPage.ImageId != 0)
                    {
                        <div class="overflow-hidden" style="height: 150px;">
                            <a href="/page?id=@relPage.PageId" class="d-block h-100">
                                <img width="100%" height="100%" 
                                     src="/api/Image/GetImage?imageId=@relPage.ImageId" 
                                     class="imagefit img-fluid" alt="@relPage.ContentTitle"
                                     style="transition: transform 0.3s ease; object-fit: cover;">
                            </a>
                        </div>
                    }

                    <div class="card-body p-3">
                        @if (!string.IsNullOrEmpty(relPage.Tags))
                        {
                            <small class="badge bg-secondary mb-2 d-block">@FormatTags(relPage.Tags)</small>
                        }
                        
                        <h5 class="card-title article_title">
                            <a href="/page?id=@relPage.PageId" class="text-decoration-none small">@relPage.ContentTitle</a>
                        </h5>
                        
                        <small class="text-muted d-block mb-2">
                            <i class="fas fa-calendar-alt"></i> @relPage.LastUpdated
                        </small>
                        
                        <p class="card-text article_promo text-truncate small">@relPage.PromoText</p>
                    </div>
                </div>
            }
        </div>
    }
</aside>
