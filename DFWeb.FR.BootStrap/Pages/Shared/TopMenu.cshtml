@using DFWeb.BE.Models

<ul class="navbar-nav">
    @foreach (var item in Model.menuItems)
    {
        if (item.ParentID == 0)
        {
            <li class="nav-item">
                <a class="nav-link" href="/mainpage?id=@item.ID">@item.Name</a>
            </li>
        }
    }
</ul>

@if (Model.UserInfoModel.IsLoggedIn == false)
{
    <div class="d-flex ms-auto align-items-center w-100 w-lg-auto mt-3 mt-lg-0">
        <form class="d-flex flex-wrap gap-2 align-items-center w-100 top-login-form" action="/api/Login/LoginUser" method="POST">
            <input name="username" class="form-control form-control-sm top-login-input" type="text" placeholder="Username" aria-label="Username">
            <input name="password" class="form-control form-control-sm top-login-input" type="password" placeholder="Password" aria-label="Password">
            <button class="btn btn-primary btn-sm d-flex align-items-center gap-2 top-login-button" type="submit">
                <i class="fas fa-sign-in-alt"></i> Sign in
            </button>
        </form>
    </div>
}
else
{
    <div class="d-flex gap-3 ms-auto align-items-center">
        <span class="text-white">Welcome <strong>@Model.UserInfoModel.Handle</strong></span>
        
        <form action="/api/Login/Logout" method="POST" class="d-inline">
            <button class="btn btn-outline-light btn-sm d-flex align-items-center gap-2" type="submit">
                <i class="fas fa-sign-out-alt"></i> Sign out
            </button>
        </form>

        @if (Model.UserInfoModel.UserAccessLevel >= (int)AccessLevel.Editor)
        {
            <form action="@Model.EditUrl" method="GET" class="d-inline">
                <input type="hidden" name="id" value="@Model.PageId" />
                <button class="btn btn-outline-light btn-sm d-flex align-items-center gap-2" type="submit">
                    <i class="fas fa-edit"></i> Edit
                </button>
            </form>
        }
    </div>
}
