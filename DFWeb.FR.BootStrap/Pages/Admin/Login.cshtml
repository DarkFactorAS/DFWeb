@page
@model LoginModel
@{
    ViewData["Title"] = "Admin Login";
}

@section Navigation {
    <ul class="navbar-nav ms-auto">
        @await Html.PartialAsync("/Pages/Views/TopElements/TopMenu.cshtml", Model)
    </ul>
}

<!-- Breadcrumb Navigation -->
<div class="row mb-4">
    <div class="col-12">
        @await Html.PartialAsync("/Pages/Views/TopElements/TopNavigation.cshtml", Model)
    </div>
</div>

<!-- Login Form -->
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card shadow-lg fade-in">
            <div class="card-header bg-primary text-white text-center py-4">
                <h2 class="mb-0">
                    <i class="fas fa-lock me-2"></i> Admin Login
                </h2>
            </div>
            
            <div class="card-body p-5">
                <form method="POST">
                    <div class="mb-4">
                        <label for="username" class="form-label fw-bold">
                            <i class="fas fa-user me-2"></i> Username
                        </label>
                        <input name="Username" id="username" class="form-control form-control-lg" 
                               type="text" placeholder="Enter your username" required>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold">
                            <i class="fas fa-key me-2"></i> Password
                        </label>
                        <input name="Password" id="password" class="form-control form-control-lg" 
                               type="password" placeholder="Enter your password" required>
                    </div>

                    <button class="btn btn-primary btn-lg w-100" type="submit">
                        <i class="fas fa-sign-in-alt me-2"></i> Login
                    </button>
                </form>

                <hr class="my-4">

                <p class="text-center text-muted mb-0">
                    <small>
                        <i class="fas fa-info-circle"></i> 
                        For security purposes, please ensure you're in a secure location before logging in.
                    </small>
                </p>
            </div>
        </div>
    </div>
</div>

